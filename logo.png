const fs = require("fs");
const path = require("path");
const multer = require("multer");

const app = express();

// Middleware
app.use(express.json());
app.use(express.static(__dirname));

// 📁 Ensure uploads folder exists
const uploadDir = path.join(__dirname, "uploads");
if (!fs.existsSync(uploadDir)) {
    fs.mkdirSync(uploadDir);
}

// ⚙️ Multer setup
const storage = multer.diskStorage({
    destination: (req, file, cb) =&gt; {
        cb(null, uploadDir);
    },
    filename: (req, file, cb) =&gt; {
        cb(null, Date.now() + "-" + file.originalname);
    }
});

const upload = multer({ storage });

// 📤 Upload route
app.post("/upload", upload.single("file"), (req, res) =&gt; {
    if (!req.file) {
        return res.status(400).json({ error: "No file uploaded" });
    }

    res.json({ file: req.file.filename });
});

// 📥 Serve uploaded files
app.use("/uploads", express.static(uploadDir));

// 📄 Get document
app.get("/doc/:id", (req, res) =&gt; {
    const filePath = path.join(__dirname, <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">data_${req.params.id}.txt</code>);

    if (fs.existsSync(filePath)) {
        res.send(fs.readFileSync(filePath, "utf-8"));
    } else {
        res.send("");
    }
});

// 💾 Save document
app.post("/doc/:id", (req, res) =&gt; {
    const filePath = path.join(__dirname, <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">data_${req.params.id}.txt</code>);
    fs.writeFileSync(filePath, req.body.content || "");
    res.send("saved");
});

// 🌐 Catch-all route (IMPORTANT FIX)
app.use((req, res) =&gt; {
    res.sendFile(path.join(__dirname, "index.html"));
});

// 🚀 Start server
app.listen(3000, () =&gt; {
