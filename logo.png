ef="/cdn/assets/sprites-core-df3050c8.svg#6d87e1" fill="currentColor"></use></svg></div></button></span><div aria-label="Toggle view" class="group relative flex gap-0.5 rounded-full p-0.5 bg-token-bg-secondary dark:bg-gray-1000"><div aria-hidden="true" class="bg-token-bg-primary pointer-events-none absolute start-0.5 top-0.5 h-8 w-8 rounded-full" style="transform: none;"></div><span class="" data-state="closed"><button type="button" aria-label="Code" aria-pressed="true" class="relative flex h-8 w-8 items-center justify-center transition-colors text-token-text-primary group-hover:text-token-text-secondary hover:text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true"><use href="/cdn/assets/sprites-core-df3050c8.svg#00f12a" fill="currentColor"></use></svg></button></span><span class="" data-state="closed"><button type="button" aria-label="Preview" aria-pressed="false" aria-disabled="false" class="relative flex h-8 w-8 items-center justify-center transition-colors text-token-text-secondary group-hover:text-token-text-secondary hover:text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true"><use href="/cdn/assets/sprites-core-df3050c8.svg#6ef7a4" fill="currentColor"></use></svg></button></span></div></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="w-full overflow-x-hidden overflow-y-auto" style="transform: none; max-height: 433px;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼm">&lt;!DOCTYPE html&gt;</span><br><span class="ͼv">&lt;html&gt;</span><br><span class="ͼv">&lt;head&gt;</span><br><span>  </span><span class="ͼv">&lt;title&gt;</span><span>Dontpad Easy Clone</span><span class="ͼv">&lt;/title&gt;</span><br><span class="ͼv">&lt;/head&gt;</span><br><span class="ͼv">&lt;body&gt;</span><br><span>  </span><span class="ͼv">&lt;h2&gt;</span><span>Dontpad Clone</span><span class="ͼv">&lt;/h2&gt;</span><br><span>  </span><span class="ͼv">&lt;textarea</span><span> </span><span class="ͼu">id</span><span class="ͼn">=</span><span class="ͼr">"editor"</span><span> </span><span class="ͼu">style</span><span class="ͼn">=</span><span class="ͼr">"</span><span>width:</span><span class="ͼq">100</span><span class="ͼn">%</span><span>; height:</span><span class="ͼq">90</span><span class="ͼn">vh</span><span>;</span><span class="ͼr">"</span><span class="ͼv">&gt;&lt;/textarea&gt;</span><br><br><span>  </span><span class="ͼl">&lt;!-- Firebase --&gt;</span><br><span>  </span><span class="ͼv">&lt;script</span><span> </span><span class="ͼu">src</span><span class="ͼn">=</span><span class="ͼr">"https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js"</span><span class="ͼv">&gt;&lt;/script&gt;</span><br><span>  </span><span class="ͼv">&lt;script</span><span> </span><span class="ͼu">src</span><span class="ͼn">=</span><span class="ͼr">"https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js"</span><span class="ͼv">&gt;&lt;/script&gt;</span><br><br><span>  </span><span class="ͼv">&lt;script&gt;</span><br><span>    </span><span class="ͼl">// 🔥 PASTE YOUR FIREBASE CONFIG HERE</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">firebaseConfig</span><span> </span><span class="ͼn">=</span><span> {</span><br><span>      apiKey: </span><span class="ͼr">"YOUR_KEY"</span><span>,</span><br><span>      authDomain: </span><span class="ͼr">"YOUR_DOMAIN"</span><span>,</span><br><span>      projectId: </span><span class="ͼr">"YOUR_PROJECT_ID"</span><span>,</span><br><span>    };</span><br><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">app</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">firebase</span><span class="ͼn">.</span><span>initializeApp(</span><span class="ͼt">firebaseConfig</span><span>);</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">db</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">firebase</span><span class="ͼn">.</span><span>firestore();</span><br><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">editor</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"editor"</span><span>);</span><br><br><span>    </span><span class="ͼl">// Get doc ID from URL</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">docId</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">window</span><span class="ͼn">.</span><span>location</span><span class="ͼn">.</span><span>pathname</span><span class="ͼn">.</span><span>substring(</span><span class="ͼq">1</span><span>) </span><span class="ͼn">||</span><span> </span><span class="ͼr">"default"</span><span>;</span><br><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">docRef</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">db</span><span class="ͼn">.</span><span>collection(</span><span class="ͼr">"docs"</span><span>)</span><span class="ͼn">.</span><span>doc(</span><span class="ͼt">docId</span><span>);</span><br><br><span>    </span><span class="ͼl">// Load real-time data</span><br><span>    </span><span class="ͼt">docRef</span><span class="ͼn">.</span><span>onSnapshot((</span><span class="ͼt">doc</span><span>) =&gt; {</span><br><span>      </span><span class="ͼn">if</span><span> (</span><span class="ͼt">doc</span><span class="ͼn">.</span><span>exists) {</span><br><span>        </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value </span><span class="ͼn">=</span><span> </span><span class="ͼt">doc</span><span class="ͼn">.</span><span>data()</span><span class="ͼn">.</span><span>content;</span><br><span>      }</span><br><span>    });</span><br><br><span>    </span><span class="ͼl">// Save changes</span><br><span>    </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>addEventListener(</span><span class="ͼr">"input"</span><span>, () =&gt; {</span><br><span>      </span><span class="ͼt">docRef</span><span class="ͼn">.</span><span>set({ content: </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value });</span><br><span>    });</span><br><span>  </span><span class="ͼv">&lt;/script&gt;</span><br><span class="ͼv">&lt;/body&gt;</span><br><span class="ͼv">&lt;/html&gt;</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
