a-testid="bad-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-df3050c8.svg#2126ae" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Share" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-df3050c8.svg#630ca2" fill="currentColor"></use></svg></span></button><span class="" data-state="closed"><button type="button" id="radix-_r_46h_" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="cursor-pointer touch:px-2.5 text-token-text-secondary hover:bg-token-bg-secondary h-[30px] rounded-md px-1.5" aria-label="Switch model"><div class="flex items-center"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-df3050c8.svg#ec66f0" fill="currentColor"></use></svg></div></button></span><button class="text-token-text-secondary hover:bg-token-bg-secondary touch:w-10 flex h-8 w-8 items-center justify-center rounded-lg" aria-label="More actions" type="button" id="radix-_r_1mm_" aria-haspopup="menu" aria-expanded="false" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-df3050c8.svg#f6d0e2" fill="currentColor"></use></svg></button></div></div></div></div><span class="sr-only"><br></span></section><section class="text-token-text-primary w-full focus:outline-none [--shadow-height:45px] has-data-writing-block:pointer-events-none has-data-writing-block:-mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto scroll-mt-(--header-height)" dir="auto" data-turn-id="82ce71b1-5b1f-4aec-a4ea-3ed5bb0cc0e8" data-testid="conversation-turn-59" data-scroll-anchor="false" data-turn="user"><h4 class="sr-only select-none">You said:</h4><div class="text-base my-auto mx-auto pt-12 [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="user" data-message-id="82ce71b1-5b1f-4aec-a4ea-3ed5bb0cc0e8" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="user-message-bubble-color corner-superellipse/0.98 relative min-w-0 rounded-[22px] px-4 py-2.5 leading-6 max-w-(--user-chat-width,70%)"><div class="[overflow-wrap:anywhere] whitespace-pre-wrap">&lt;!DOCTYPE html&gt;
&lt;html&gt;
&lt;head&gt;
  &lt;title&gt;YeahPad&lt;/title&gt;
  &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;

  &lt;style&gt;
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto;
      background-color: #F3F2EF;
    }

    .navbar {
      background: #ffffff;
      display: flex;
      align-items: center;
      padding: 10px 20px;
      border-bottom: 1px solid #e0e0e0;
    }

    .logo {
      color: #0A66C2;
      font-size: 22px;
      font-weight: bold;
    }

    .main {
      display: flex;
      justify-content: center;
      margin-top: 30px;
    }

    .card {
      width: 600px;
      background: #ffffff;
      border-radius: 8px;
      border: 1px solid #e0e0e0;
      padding: 15px;
    }

    .doc-name {
      font-size: 14px;
      color: #666;
      margin-bottom: 10px;
    }

    textarea {
      width: 100%;
      height: 250px;
      border: none;
      outline: none;
      resize: none;
      font-size: 16px;
      line-height: 1.6;
      font-family: inherit;
    }

    .card:hover {
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .upload-box {
      margin-top: 10px;
    }

    input[type="file"] {
      margin-top: 10px;
    }

    button {
      background: #0A66C2;
      color: white;
      border: none;
      padding: 8px 14px;
      border-radius: 5px;
      cursor: pointer;
      margin-top: 10px;
    }

    button:hover {
      background: #004182;
    }

    #files {
      margin-top: 15px;
    }

    img {
      max-width: 100%;
      margin-top: 10px;
      border-radius: 6px;
    }

    iframe {
      margin-top: 10px;
      border-radius: 6px;
    }

    a {
      display: block;
      margin-top: 8px;
      color: #0A66C2;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }
  &lt;/style&gt;
&lt;/head&gt;

&lt;body&gt;

  &lt;div class="navbar"&gt;
    &lt;div class="logo"&gt;YeahPad&lt;/div&gt;
  &lt;/div&gt;

  &lt;div class="main"&gt;
    &lt;div class="card"&gt;

      &lt;div class="doc-name" id="docName"&gt;&lt;/div&gt;

      &lt;textarea id="editor" placeholder="Start writing your thoughts..."&gt;&lt;/textarea&gt;

      &lt;div class="upload-box"&gt;
        &lt;input type="file" id="fileInput"&gt;
        &lt;br&gt;
        &lt;button onclick="uploadFile()"&gt;Upload File&lt;/button&gt;
      &lt;/div&gt;

      &lt;div id="files"&gt;&lt;/div&gt;

    &lt;/div&gt;
  &lt;/div&gt;

  &lt;script&gt;
    const editor = document.getElementById("editor");
    const docName = document.getElementById("docName");
    const filesDiv = document.getElementById("files");

    const docId = window.location.pathname.substring(1) || "default";
    docName.innerText = "Document: " + docId;

    // LOAD TEXT
    async function load() {
      try {
        const res = await fetch("/doc/" + docId);
        const text = await res.text();
        editor.value = text;
      } catch (err) {
        console.error("Load error:", err);
      }
    }

    // SAVE TEXT
    async function save() {
      try {
        await fetch("/doc/" + docId, {
          method: "POST",
          headers: {"Content-Type": "application/json"},
          body: JSON.stringify({ content: editor.value })
        });
      } catch (err) {
        console.error("Save error:", err);
      }
    }

    setInterval(save, 2000);
    load();

    // FILE UPLOAD
    async function uploadFile() {
      const fileInput = document.getElementById("fileInput");
      const file = fileInput.files[0];

      if (!file) {
        alert("Please select a file");
        return;
      }

      const formData = new FormData();
      formData.append("file", file);

      try {
        const res = await fetch("/upload", {
          method: "POST",
          body: formData
        });

        const data = await res.json();

        console.log("Upload success:", data);

        // ✅ FIXED URL
        const fileUrl = window.location.origin + "/uploads/" + data.file;

        // clear input
        fileInput.value = "";

        // SHOW FILE
        if (file.type.startsWith("image")) {
          filesDiv.innerHTML += <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;img src="${fileUrl}"&gt;</code>;
        } 
        else if (file.type === "application/pdf") {
          filesDiv.innerHTML += <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;iframe src="${fileUrl}" width="100%" height="300"&gt;&lt;/iframe&gt;</code>;
        } 
        else {
          filesDiv.innerHTML += <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;a href="${fileUrl}" target="_blank"&gt;📄 ${data.file}&lt;/a&gt;</code>;
        }

      } catch (err) {
        console.error("Upload error:", err);
        alert("Upload failed");
      }
    }
  &lt;/script&gt;

&lt;/body&gt;
