mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto scroll-mt-(--header-height)" dir="auto" data-turn-id="e42b0538-deca-4e76-aa77-06ca89d96016" data-testid="conversation-turn-83" data-scroll-anchor="false" data-turn="user"><h4 class="sr-only select-none">You said:</h4><div class="text-base my-auto mx-auto pt-12 [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="user" data-message-id="e42b0538-deca-4e76-aa77-06ca89d96016" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="user-message-bubble-color corner-superellipse/0.98 relative min-w-0 rounded-[22px] px-4 py-2.5 leading-6 max-w-(--user-chat-width,70%)"><div class="[overflow-wrap:anywhere] whitespace-pre-wrap">&lt;!DOCTYPE html&gt;
&lt;html&gt;
&lt;head&gt;
  &lt;title&gt;YeahPad&lt;/title&gt;
  &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;

  &lt;style&gt;
    body {
      margin: 0;
      font-family: "Segoe UI", Roboto;
      background-color: #F3F2EF;
    }

    .navbar {
      background: #fff;
      padding: 10px 20px;
      border-bottom: 1px solid #ddd;
    }

    .logo {
      color: #0A66C2;
      font-size: 22px;
      font-weight: bold;
    }

    .main {
      display: flex;
      justify-content: center;
      margin-top: 30px;
    }

    .card {
      width: 600px;
      background: #fff;
      border-radius: 8px;
      border: 1px solid #ddd;
      padding: 15px;
    }

    textarea {
      width: 100%;
      height: 200px;
      border: none;
      outline: none;
      font-size: 16px;
    }

    button {
      background: #0A66C2;
      color: white;
      padding: 6px 10px;
      border: none;
      margin-top: 10px;
      cursor: pointer;
      border-radius: 4px;
    }

    .file-box {
      margin-top: 10px;
    }

    img {
      max-width: 100%;
    }

    iframe {
      width: 100%;
      height: 250px;
    }
  &lt;/style&gt;
&lt;/head&gt;

&lt;body&gt;

&lt;div class="navbar"&gt;
  &lt;div class="logo"&gt;YeahPad&lt;/div&gt;
&lt;/div&gt;

&lt;div class="main"&gt;
  &lt;div class="card"&gt;

    &lt;div id="docName"&gt;&lt;/div&gt;

    &lt;textarea id="editor"&gt;&lt;/textarea&gt;

    &lt;input type="file" id="fileInput"&gt;
    &lt;button onclick="uploadFile()"&gt;Upload&lt;/button&gt;

    &lt;div id="files"&gt;&lt;/div&gt;

  &lt;/div&gt;
&lt;/div&gt;

&lt;script&gt;
const editor = document.getElementById("editor");
const filesDiv = document.getElementById("files");
const docName = document.getElementById("docName");

const docId = window.location.pathname.substring(1) || "default";
docName.innerText = "Document: " + docId;

let currentFiles = [];

// 🔥 LOAD
async function load() {
  const res = await fetch("/doc/" + docId);
  const data = await res.json();

  editor.value = data.content || "";
  currentFiles = data.files || [];

  filesDiv.innerHTML = "";
  currentFiles.push(data.url);
}

// 🔥 SAVE
async function save() {
  await fetch("/doc/" + docId, {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({
      content: editor.value,
      files: currentFiles
    })
  });
}

setInterval(save, 2000);

// 🔥 SHOW FILE
function showFile(fileUrl) {

  const div = document.createElement("div");

  if (fileUrl.match(/\.(jpg|png|jpeg|gif)$/)) {
    div.innerHTML = <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;img src="${fileUrl}"&gt;</code>;
  } 
  else if (fileUrl.includes(".pdf")) {
    div.innerHTML = <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;iframe src="${fileUrl}"&gt;&lt;/iframe&gt;</code>;
  } 
  else {
    div.innerHTML = <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;a href="${fileUrl}" target="_blank"&gt;${fileUrl}&lt;/a&gt;</code>;
  }

  filesDiv.appendChild(div);
}

// 🔥 DELETE FILE
function deleteFile(file) {
  currentFiles = currentFiles.filter(f =&gt; f !== file);
  filesDiv.innerHTML = "";
  currentFiles.forEach(showFile);
}

// 🔥 UPLOAD
async function uploadFile() {
  const fileInput = document.getElementById("fileInput");
  const file = fileInput.files[0];

  if (!file) return alert("Select file");

  const formData = new FormData();
  formData.append("file", file);

  const res = await fetch("/upload", {
    method: "POST",
    body: formData
  });

  const data = await res.json();

  currentFiles.push(data.file);
  showFile(data.file);

  fileInput.value = "";
}

load();

&lt;/script&gt;

&lt;/body&gt;
