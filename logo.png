ass="ͼu">onclick</span><span class="ͼn">=</span><span class="ͼr">"</span><span class="ͼt">uploadFile</span><span>()</span><span class="ͼr">"</span><span class="ͼv">&gt;</span><span>Upload</span><span class="ͼv">&lt;/button&gt;</span><br><br><span>    </span><span class="ͼv">&lt;div</span><span> </span><span class="ͼu">id</span><span class="ͼn">=</span><span class="ͼr">"files"</span><span class="ͼv">&gt;&lt;/div&gt;</span><br><br><span>  </span><span class="ͼv">&lt;/div&gt;</span><br><span class="ͼv">&lt;/div&gt;</span><br><br><span class="ͼv">&lt;footer&gt;</span><br><span>  </span><span class="ͼv">&lt;a</span><span> </span><span class="ͼu">href</span><span class="ͼn">=</span><span class="ͼr">"/privacy.html"</span><span class="ͼv">&gt;</span><span>Privacy Policy</span><span class="ͼv">&lt;/a&gt;</span><br><span>  </span><span class="ͼv">&lt;a</span><span> </span><span class="ͼu">href</span><span class="ͼn">=</span><span class="ͼr">"/terms.html"</span><span class="ͼv">&gt;</span><span>Terms</span><span class="ͼv">&lt;/a&gt;</span><br><span>  </span><span class="ͼv">&lt;a</span><span> </span><span class="ͼu">href</span><span class="ͼn">=</span><span class="ͼr">"/about.html"</span><span class="ͼv">&gt;</span><span>About</span><span class="ͼv">&lt;/a&gt;</span><br><span>  </span><span class="ͼv">&lt;a</span><span> </span><span class="ͼu">href</span><span class="ͼn">=</span><span class="ͼr">"/contact.html"</span><span class="ͼv">&gt;</span><span>Contact</span><span class="ͼv">&lt;/a&gt;</span><br><span class="ͼv">&lt;/footer&gt;</span><br><br><span class="ͼv">&lt;script&gt;</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">filesDiv</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"files"</span><span>);</span><br><br><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">uploadFile</span><span>() {</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"fileInput"</span><span>)</span><span class="ͼn">.</span><span>files[</span><span class="ͼq">0</span><span>];</span><br><span>  </span><span class="ͼn">if</span><span> (</span><span class="ͼn">!</span><span class="ͼt">file</span><span>) </span><span class="ͼn">return</span><span> </span><span class="ͼt">alert</span><span>(</span><span class="ͼr">"Select file"</span><span>);</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">formData</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">new</span><span> </span><span class="ͼt">FormData</span><span>();</span><br><span>  </span><span class="ͼt">formData</span><span class="ͼn">.</span><span>append(</span><span class="ͼr">"file"</span><span>, </span><span class="ͼt">file</span><span>);</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">res</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">"/upload"</span><span>, { method: </span><span class="ͼr">"POST"</span><span>, body: </span><span class="ͼt">formData</span><span> });</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">data</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">res</span><span class="ͼn">.</span><span>json();</span><br><br><span>  </span><span class="ͼt">showFile</span><span>(</span><span class="ͼt">data</span><span class="ͼn">.</span><span>url);</span><br><span>}</span><br><br><span class="ͼn">function</span><span> </span><span class="ͼt">showFile</span><span>(</span><span class="ͼt">url</span><span>) {</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">div</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>createElement(</span><span class="ͼr">"div"</span><span>);</span><br><span>  </span><span class="ͼt">div</span><span class="ͼn">.</span><span>className </span><span class="ͼn">=</span><span> </span><span class="ͼr">"file-box"</span><span>;</span><br><br><span>  </span><span class="ͼn">if</span><span> (</span><span class="ͼt">url</span><span class="ͼn">.</span><span>match(</span><span class="ͼr">/\.(jpg|png|jpeg|gif)$/</span><span>)) {</span><br><span>    </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼr">`&lt;img src="</span><span>${</span><span class="ͼt">url</span><span>}</span><span class="ͼr">"&gt;`</span><span>;</span><br><span>  } </span><span class="ͼn">else</span><span> </span><span class="ͼn">if</span><span> (</span><span class="ͼt">url</span><span class="ͼn">.</span><span>includes(</span><span class="ͼr">".pdf"</span><span>)) {</span><br><span>    </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼr">`&lt;iframe src="</span><span>${</span><span class="ͼt">url</span><span>}</span><span class="ͼr">"&gt;&lt;/iframe&gt;`</span><span>;</span><br><span>  } </span><span class="ͼn">else</span><span> {</span><br><span>    </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼr">`&lt;a href="</span><span>${</span><span class="ͼt">url</span><span>}</span><span class="ͼr">" target="_blank"&gt;</span><span>${</span><span class="ͼt">url</span><span>}</span><span class="ͼr">&lt;/a&gt;`</span><span>;</span><br><span>  }</span><br><br><span>  </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">+=</span><span> </span><span class="ͼr">`</span><br><span class="ͼr">    &lt;div class="actions"&gt;</span><br><span class="ͼr">      &lt;span&gt;Like&lt;/span&gt;</span><br><span class="ͼr">      &lt;span&gt;Comment&lt;/span&gt;</span><br><span class="ͼr">      &lt;span&gt;Share&lt;/span&gt;</span><br><span class="ͼr">    &lt;/div&gt;</span><br><span class="ͼr">  `</span><span>;</span><br><br><span>  </span><span class="ͼt">filesDiv</span><span class="ͼn">.</span><span>appendChild(</span><span class="ͼt">div</span><span>);</span><br><span>}</span><br><span class="ͼv">&lt;/script&gt;</span><br><br><span class="ͼv">&lt;/body&gt;</span><br><span class="ͼv">&lt;/html&gt;</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
