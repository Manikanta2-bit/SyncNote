m-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼv">&lt;script&gt;</span><br><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">uploadFile</span><span>() {</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">fileInput</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"fileInput"</span><span>);</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">fileInput</span><span class="ͼn">.</span><span>files[</span><span class="ͼq">0</span><span>];</span><br><br><span>  </span><span class="ͼn">if</span><span> (</span><span class="ͼn">!</span><span class="ͼt">file</span><span>) </span><span class="ͼn">return</span><span> </span><span class="ͼt">alert</span><span>(</span><span class="ͼr">"Select a file"</span><span>);</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">formData</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">new</span><span> </span><span class="ͼt">FormData</span><span>();</span><br><span>  </span><span class="ͼt">formData</span><span class="ͼn">.</span><span>append(</span><span class="ͼr">"file"</span><span>, </span><span class="ͼt">file</span><span>);</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">res</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">"/upload"</span><span>, {</span><br><span>    method: </span><span class="ͼr">"POST"</span><span>,</span><br><span>    body: </span><span class="ͼt">formData</span><br><span>  });</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">data</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">res</span><span class="ͼn">.</span><span>json();</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">fileUrl</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">"/uploads/"</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">data</span><span class="ͼn">.</span><span>file;</span><br><br><span>  </span><span class="ͼl">// Show file</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">div</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"files"</span><span>);</span><br><br><span>  </span><span class="ͼn">if</span><span> (</span><span class="ͼt">file</span><span class="ͼn">.</span><span>type</span><span class="ͼn">.</span><span>startsWith(</span><span class="ͼr">"image"</span><span>)) {</span><br><span>    </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">+=</span><span> </span><span class="ͼr">`&lt;img src="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">" width="200"&gt;&lt;br&gt;`</span><span>;</span><br><span>  } </span><span class="ͼn">else</span><span> {</span><br><span>    </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">+=</span><span> </span><span class="ͼr">`&lt;a href="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">" target="_blank"&gt;</span><span>${</span><span class="ͼt">data</span><span class="ͼn">.</span><span>file}</span><span class="ͼr">&lt;/a&gt;&lt;br&gt;`</span><span>;</span><br><span>  }</span><br><span>}</span><br><span class="ͼv">&lt;/script&gt;</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
