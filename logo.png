tive z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">const</span><span> </span><span class="ͼt">express</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">require</span><span>(</span><span class="ͼr">"express"</span><span>);</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">http</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">require</span><span>(</span><span class="ͼr">"http"</span><span>);</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">mongoose</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">require</span><span>(</span><span class="ͼr">"mongoose"</span><span>);</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">cors</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">require</span><span>(</span><span class="ͼr">"cors"</span><span>);</span><br><span class="ͼn">const</span><span> { Server } </span><span class="ͼn">=</span><span> </span><span class="ͼt">require</span><span>(</span><span class="ͼr">"socket.io"</span><span>);</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">Doc</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">require</span><span>(</span><span class="ͼr">"./models/Doc"</span><span>);</span><br><br><span class="ͼn">const</span><span> </span><span class="ͼt">app</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">express</span><span>();</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>use(</span><span class="ͼt">cors</span><span>());</span><br><br><span class="ͼt">mongoose</span><span class="ͼn">.</span><span>connect(</span><span class="ͼr">"mongodb://127.0.0.1:27017/dontpad"</span><span>);</span><br><br><span class="ͼn">const</span><span> </span><span class="ͼt">server</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">http</span><span class="ͼn">.</span><span>createServer(</span><span class="ͼt">app</span><span>);</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">io</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">new</span><span> </span><span class="ͼt">Server</span><span>(</span><span class="ͼt">server</span><span>, {</span><br><span>    cors: { origin: </span><span class="ͼr">"*"</span><span> }</span><br><span>});</span><br><br><span class="ͼl">// Get or create doc</span><br><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">findOrCreateDoc</span><span>(</span><span class="ͼt">id</span><span>) {</span><br><span>    </span><span class="ͼn">let</span><span> </span><span class="ͼt">doc</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">Doc</span><span class="ͼn">.</span><span>findOne({ docId: </span><span class="ͼt">id</span><span> });</span><br><span>    </span><span class="ͼn">if</span><span> (</span><span class="ͼn">!</span><span class="ͼt">doc</span><span>) {</span><br><span>        </span><span class="ͼt">doc</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">Doc</span><span class="ͼn">.</span><span>create({ docId: </span><span class="ͼt">id</span><span>, content: </span><span class="ͼr">""</span><span> });</span><br><span>    }</span><br><span>    </span><span class="ͼn">return</span><span> </span><span class="ͼt">doc</span><span>;</span><br><span>}</span><br><br><span class="ͼl">// WebSocket logic</span><br><span class="ͼt">io</span><span class="ͼn">.</span><span>on(</span><span class="ͼr">"connection"</span><span>, (</span><span class="ͼt">socket</span><span>) =&gt; {</span><br><br><span>    </span><span class="ͼt">socket</span><span class="ͼn">.</span><span>on(</span><span class="ͼr">"get-document"</span><span>, </span><span class="ͼn">async</span><span> (</span><span class="ͼt">docId</span><span>) =&gt; {</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">doc</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">findOrCreateDoc</span><span>(</span><span class="ͼt">docId</span><span>);</span><br><br><span>        </span><span class="ͼt">socket</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">docId</span><span>);</span><br><span>        </span><span class="ͼt">socket</span><span class="ͼn">.</span><span>emit(</span><span class="ͼr">"load-document"</span><span>, </span><span class="ͼt">doc</span><span class="ͼn">.</span><span>content);</span><br><br><span>        </span><span class="ͼt">socket</span><span class="ͼn">.</span><span>on(</span><span class="ͼr">"send-changes"</span><span>, (</span><span class="ͼt">delta</span><span>) =&gt; {</span><br><span>            </span><span class="ͼt">socket</span><span class="ͼn">.</span><span>broadcast</span><span class="ͼn">.</span><span>to(</span><span class="ͼt">docId</span><span>)</span><span class="ͼn">.</span><span>emit(</span><span class="ͼr">"receive-changes"</span><span>, </span><span class="ͼt">delta</span><span>);</span><br><span>        });</span><br><br><span>        </span><span class="ͼt">socket</span><span class="ͼn">.</span><span>on(</span><span class="ͼr">"save-document"</span><span>, </span><span class="ͼn">async</span><span> (</span><span class="ͼt">data</span><span>) =&gt; {</span><br><span>            </span><span class="ͼn">await</span><span> </span><span class="ͼt">Doc</span><span class="ͼn">.</span><span>findOneAndUpdate({ docId }, { content: </span><span class="ͼt">data</span><span> });</span><br><span>        });</span><br><span>    });</span><br><span>});</span><br><br><span class="ͼt">server</span><span class="ͼn">.</span><span>listen(</span><span class="ͼq">3000</span><span>, () =&gt; </span><span class="ͼt">console</span><span class="ͼn">.</span><span>log(</span><span class="ͼr">"Server running on port 3000"</span><span>));</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
