pan><span class="ͼn">if</span><span> (</span><span class="ͼt">fs</span><span class="ͼn">.</span><span>existsSync(</span><span class="ͼt">file</span><span>)) {</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼt">fs</span><span class="ͼn">.</span><span>readFileSync(</span><span class="ͼt">file</span><span>, </span><span class="ͼr">"utf-8"</span><span>));</span><br><span>    } </span><span class="ͼn">else</span><span> {</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼr">""</span><span>);</span><br><span>    }</span><br><span>});</span><br><br><span class="ͼt">app</span><span class="ͼn">.</span><span>post(</span><span class="ͼr">"/doc/:id"</span><span>, (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">`data_</span><span>${</span><span class="ͼt">req</span><span class="ͼn">.</span><span>params</span><span class="ͼn">.</span><span>id}</span><span class="ͼr">.txt`</span><span>;</span><br><span>    </span><span class="ͼt">fs</span><span class="ͼn">.</span><span>writeFileSync(</span><span class="ͼt">file</span><span>, </span><span class="ͼt">req</span><span class="ͼn">.</span><span>body</span><span class="ͼn">.</span><span>content </span><span class="ͼn">||</span><span> </span><span class="ͼr">""</span><span>);</span><br><span>    </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼr">"saved"</span><span>);</span><br><span>});</span><br><br><span class="ͼl">// 🔥 THIS FIXES YOUR ERROR</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"*"</span><span>, (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼt">res</span><span class="ͼn">.</span><span>sendFile(</span><span class="ͼt">path</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">__dirname</span><span>, </span><span class="ͼr">"index.html"</span><span>));</span><br><span>});</span><br><br><span class="ͼt">app</span><span class="ͼn">.</span><span>listen(</span><span class="ͼq">3000</span><span>, () =&gt; {</span><br><span>    </span><span class="ͼt">console</span><span class="ͼn">.</span><span>log(</span><span class="ͼr">"Running on http://localhost:3000"</span><span>);</span><br><span>});</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
