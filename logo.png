<h1 data-section-id="16g91qu" data-start="1625" data-end="1658">🌐 Step 4: Frontend (HTML + JS)</h1>
<h3 data-section-id="gs20eo" data-start="1660" data-end="1693"><span role="text">📌 Create <code data-start="1674" data-end="1693">public/index.html</code></span></h3>
<pre class="overflow-visible! px-0!" data-start="1694" data-end="2673"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-df3050c8.svg#e45ab3" fill="currentColor"></use></svg>HTML</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-df3050c8.svg#ce3544" fill="currentColor"></use></svg></button><span class="" data-state="closed"><button class="btn relative group-focus-within/dialog:focus-visible:[outline-width:1.5px] group-focus-within/dialog:focus-visible:[outline-offset:2.5px] group-focus-within/dialog:focus-visible:[outline-style:solid] group-focus-within/dialog:focus-visible:[outline-color:var(--text-primary)] btn-ghost size-9" aria-label="Edit"><div class="flex w-full items-center justify-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-label="" class="-mx-1 icon"><use href="/cdn/assets/sprites-core-df3050c8.svg#6d87e1" fill="currentColor"></use></svg></div></button></span><div aria-label="Toggle view" class="group relative flex gap-0.5 rounded-full p-0.5 bg-token-bg-secondary dark:bg-gray-1000"><div aria-hidden="true" class="bg-token-bg-primary pointer-events-none absolute start-0.5 top-0.5 h-8 w-8 rounded-full" style="transform: none;"></div><span class="" data-state="closed"><button type="button" aria-label="Code" aria-pressed="true" class="relative flex h-8 w-8 items-center justify-center transition-colors text-token-text-primary group-hover:text-token-text-secondary hover:text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true"><use href="/cdn/assets/sprites-core-df3050c8.svg#00f12a" fill="currentColor"></use></svg></button></span><span class="" data-state="closed"><button type="button" aria-label="Preview" aria-pressed="false" aria-disabled="false" class="relative flex h-8 w-8 items-center justify-center transition-colors text-token-text-secondary group-hover:text-token-text-secondary hover:text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true"><use href="/cdn/assets/sprites-core-df3050c8.svg#6ef7a4" fill="currentColor"></use></svg></button></span></div></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="w-full overflow-x-hidden overflow-y-auto" style="transform: none; max-height: 433px;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼm">&lt;!DOCTYPE html&gt;</span><br><span class="ͼv">&lt;html&gt;</span><br><span class="ͼv">&lt;head&gt;</span><br><span>    </span><span class="ͼv">&lt;title&gt;</span><span>Dontpad Clone</span><span class="ͼv">&lt;/title&gt;</span><br><span class="ͼv">&lt;/head&gt;</span><br><span class="ͼv">&lt;body&gt;</span><br><span>    </span><span class="ͼv">&lt;h2&gt;</span><span>Dontpad Clone</span><span class="ͼv">&lt;/h2&gt;</span><br><span>    </span><span class="ͼv">&lt;textarea</span><span> </span><span class="ͼu">id</span><span class="ͼn">=</span><span class="ͼr">"editor"</span><span> </span><span class="ͼu">style</span><span class="ͼn">=</span><span class="ͼr">"</span><span>width:</span><span class="ͼq">100</span><span class="ͼn">%</span><span>; height:</span><span class="ͼq">90</span><span class="ͼn">vh</span><span>;</span><span class="ͼr">"</span><span class="ͼv">&gt;&lt;/textarea&gt;</span><br><br><span>    </span><span class="ͼv">&lt;script&gt;</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">editor</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"editor"</span><span>);</span><br><br><span>        </span><span class="ͼl">// Get doc ID from URL</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">docId</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">window</span><span class="ͼn">.</span><span>location</span><span class="ͼn">.</span><span>pathname</span><span class="ͼn">.</span><span>substring(</span><span class="ͼq">1</span><span>) </span><span class="ͼn">||</span><span> </span><span class="ͼr">"default"</span><span>;</span><br><br><span>        </span><span class="ͼl">// Load content</span><br><span>        </span><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">loadDoc</span><span>() {</span><br><span>            </span><span class="ͼn">const</span><span> </span><span class="ͼt">res</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">`/doc/</span><span>${</span><span class="ͼt">docId</span><span>}</span><span class="ͼr">`</span><span>);</span><br><span>            </span><span class="ͼn">const</span><span> </span><span class="ͼt">text</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">res</span><span class="ͼn">.</span><span>text();</span><br><span>            </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value </span><span class="ͼn">=</span><span> </span><span class="ͼt">text</span><span>;</span><br><span>        }</span><br><br><span>        </span><span class="ͼl">// Save content</span><br><span>        </span><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">saveDoc</span><span>() {</span><br><span>            </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">`/doc/</span><span>${</span><span class="ͼt">docId</span><span>}</span><span class="ͼr">`</span><span>, {</span><br><span>                method: </span><span class="ͼr">"POST"</span><span>,</span><br><span>                headers: { </span><span class="ͼr">"Content-Type"</span><span>: </span><span class="ͼr">"application/json"</span><span> },</span><br><span>                body: </span><span class="ͼt">JSON</span><span class="ͼn">.</span><span>stringify({ content: </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value })</span><br><span>            });</span><br><span>        }</span><br><br><span>        </span><span class="ͼl">// Auto-save every 2 seconds</span><br><span>        </span><span class="ͼt">setInterval</span><span>(</span><span class="ͼt">saveDoc</span><span>, </span><span class="ͼq">2000</span><span>);</span><br><br><span>        </span><span class="ͼt">loadDoc</span><span>();</span><br><span>    </span><span class="ͼv">&lt;/script&gt;</span><br><span class="ͼv">&lt;/body&gt;</span><br><span class="ͼv">&lt;/html&gt;</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
