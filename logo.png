">&lt;/button&gt;</span><br><span>      </span><span class="ͼv">&lt;/div&gt;</span><br><br><span>      </span><span class="ͼv">&lt;div</span><span> </span><span class="ͼu">id</span><span class="ͼn">=</span><span class="ͼr">"files"</span><span class="ͼv">&gt;&lt;/div&gt;</span><br><br><span>    </span><span class="ͼv">&lt;/div&gt;</span><br><span>  </span><span class="ͼv">&lt;/div&gt;</span><br><br><span>  </span><span class="ͼv">&lt;script&gt;</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">editor</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"editor"</span><span>);</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">docName</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"docName"</span><span>);</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">filesDiv</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"files"</span><span>);</span><br><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">docId</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">window</span><span class="ͼn">.</span><span>location</span><span class="ͼn">.</span><span>pathname</span><span class="ͼn">.</span><span>substring(</span><span class="ͼq">1</span><span>) </span><span class="ͼn">||</span><span> </span><span class="ͼr">"default"</span><span>;</span><br><span>    </span><span class="ͼt">docName</span><span class="ͼn">.</span><span>innerText </span><span class="ͼn">=</span><span> </span><span class="ͼr">"Document: "</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">docId</span><span>;</span><br><br><span>    </span><span class="ͼl">// LOAD TEXT</span><br><span>    </span><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">load</span><span>() {</span><br><span>      </span><span class="ͼn">try</span><span> {</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">res</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">"/doc/"</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">docId</span><span>);</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">text</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">res</span><span class="ͼn">.</span><span>text();</span><br><span>        </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value </span><span class="ͼn">=</span><span> </span><span class="ͼt">text</span><span>;</span><br><span>      } </span><span class="ͼn">catch</span><span> (</span><span class="ͼt">err</span><span>) {</span><br><span>        </span><span class="ͼt">console</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">"Load error:"</span><span>, </span><span class="ͼt">err</span><span>);</span><br><span>      }</span><br><span>    }</span><br><br><span>    </span><span class="ͼl">// SAVE TEXT</span><br><span>    </span><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">save</span><span>() {</span><br><span>      </span><span class="ͼn">try</span><span> {</span><br><span>        </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">"/doc/"</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">docId</span><span>, {</span><br><span>          method: </span><span class="ͼr">"POST"</span><span>,</span><br><span>          headers: {</span><span class="ͼr">"Content-Type"</span><span>: </span><span class="ͼr">"application/json"</span><span>},</span><br><span>          body: </span><span class="ͼt">JSON</span><span class="ͼn">.</span><span>stringify({ content: </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value })</span><br><span>        });</span><br><span>      } </span><span class="ͼn">catch</span><span> (</span><span class="ͼt">err</span><span>) {</span><br><span>        </span><span class="ͼt">console</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">"Save error:"</span><span>, </span><span class="ͼt">err</span><span>);</span><br><span>      }</span><br><span>    }</span><br><br><span>    </span><span class="ͼt">setInterval</span><span>(</span><span class="ͼt">save</span><span>, </span><span class="ͼq">2000</span><span>);</span><br><span>    </span><span class="ͼt">load</span><span>();</span><br><br><span>    </span><span class="ͼl">// FILE UPLOAD</span><br><span>    </span><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">uploadFile</span><span>() {</span><br><span>      </span><span class="ͼn">const</span><span> </span><span class="ͼt">fileInput</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"fileInput"</span><span>);</span><br><span>      </span><span class="ͼn">const</span><span> </span><span class="ͼt">file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">fileInput</span><span class="ͼn">.</span><span>files[</span><span class="ͼq">0</span><span>];</span><br><br><span>      </span><span class="ͼn">if</span><span> (</span><span class="ͼn">!</span><span class="ͼt">file</span><span>) {</span><br><span>        </span><span class="ͼt">alert</span><span>(</span><span class="ͼr">"Please select a file"</span><span>);</span><br><span>        </span><span class="ͼn">return</span><span>;</span><br><span>      }</span><br><br><span>      </span><span class="ͼn">const</span><span> </span><span class="ͼt">formData</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">new</span><span> </span><span class="ͼt">FormData</span><span>();</span><br><span>      </span><span class="ͼt">formData</span><span class="ͼn">.</span><span>append(</span><span class="ͼr">"file"</span><span>, </span><span class="ͼt">file</span><span>);</span><br><br><span>      </span><span class="ͼn">try</span><span> {</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">res</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">"/upload"</span><span>, {</span><br><span>          method: </span><span class="ͼr">"POST"</span><span>,</span><br><span>          body: </span><span class="ͼt">formData</span><br><span>        });</span><br><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">data</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">res</span><span class="ͼn">.</span><span>json();</span><br><br><span>        </span><span class="ͼt">console</span><span class="ͼn">.</span><span>log(</span><span class="ͼr">"Upload success:"</span><span>, </span><span class="ͼt">data</span><span>);</span><br><br><span>        </span><span class="ͼl">// ✅ FIXED URL</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">fileUrl</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">window</span><span class="ͼn">.</span><span>location</span><span class="ͼn">.</span><span>origin </span><span class="ͼn">+</span><span> </span><span class="ͼr">"/uploads/"</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">data</span><span class="ͼn">.</span><span>file;</span><br><br><span>        </span><span class="ͼl">// clear input</span><br><span>        </span><span class="ͼt">fileInput</span><span class="ͼn">.</span><span>value </span><span class="ͼn">=</span><span> </span><span class="ͼr">""</span><span>;</span><br><br><span>        </span><span class="ͼl">// SHOW FILE</span><br><span>        </span><span class="ͼn">if</span><span> (</span><span class="ͼt">file</span><span class="ͼn">.</span><span>type</span><span class="ͼn">.</span><span>startsWith(</span><span class="ͼr">"image"</span><span>)) {</span><br><span>          </span><span class="ͼt">filesDiv</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">+=</span><span> </span><span class="ͼr">`&lt;img src="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">"&gt;`</span><span>;</span><br><span>        } </span><br><span>        </span><span class="ͼn">else</span><span> </span><span class="ͼn">if</span><span> (</span><span class="ͼt">file</span><span class="ͼn">.</span><span>type </span><span class="ͼn">===</span><span> </span><span class="ͼr">"application/pdf"</span><span>) {</span><br><span>          </span><span class="ͼt">filesDiv</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">+=</span><span> </span><span class="ͼr">`&lt;iframe src="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">" width="100%" height="300"&gt;&lt;/iframe&gt;`</span><span>;</span><br><span>        } </span><br><span>        </span><span class="ͼn">else</span><span> {</span><br><span>          </span><span class="ͼt">filesDiv</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">+=</span><span> </span><span class="ͼr">`&lt;a href="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">" target="_blank"&gt;📄 </span><span>${</span><span class="ͼt">data</span><span class="ͼn">.</span><span>file}</span><span class="ͼr">&lt;/a&gt;`</span><span>;</span><br><span>        }</span><br><br><span>      } </span><span class="ͼn">catch</span><span> (</span><span class="ͼt">err</span><span>) {</span><br><span>        </span><span class="ͼt">console</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">"Upload error:"</span><span>, </span><span class="ͼt">err</span><span>);</span><br><span>        </span><span class="ͼt">alert</span><span>(</span><span class="ͼr">"Upload failed"</span><span>);</span><br><span>      }</span><br><span>    }</span><br><span>  </span><span class="ͼv">&lt;/script&gt;</span><br><br><span class="ͼv">&lt;/body&gt;</span><br><span class="ͼv">&lt;/html&gt;</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
