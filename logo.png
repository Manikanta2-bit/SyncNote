&lt;body&gt;

&lt;div class="navbar"&gt;
  &lt;div class="logo"&gt;YeahPad&lt;/div&gt;
&lt;/div&gt;

&lt;div class="main"&gt;
  &lt;div class="card"&gt;

    &lt;div id="docName"&gt;&lt;/div&gt;

    &lt;textarea id="editor"&gt;&lt;/textarea&gt;

    &lt;input type="file" id="fileInput"&gt;
    &lt;button onclick="uploadFile()"&gt;Upload&lt;/button&gt;

    &lt;div id="files"&gt;&lt;/div&gt;

  &lt;/div&gt;
&lt;/div&gt;

&lt;script&gt;
const editor = document.getElementById("editor");
const filesDiv = document.getElementById("files");
const docName = document.getElementById("docName");

const docId = window.location.pathname.substring(1) || "default";
docName.innerText = "Document: " + docId;

let currentFiles = [];

// ✅ LOAD
async function load() {
  const res = await fetch("/doc/" + docId);
  const data = await res.json();

  editor.value = data.content || "";
  currentFiles = data.files || [];

  filesDiv.innerHTML = "";

  // 🔥 IMPORTANT: render files
  currentFiles.forEach(showFile);
}

// ✅ SAVE
async function save() {
  await fetch("/doc/" + docId, {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({
      content: editor.value,
      files: currentFiles
    })
  });
}

setInterval(save, 2000);

// ✅ SHOW FILE
function showFile(file) {
  const fileUrl = "/uploads/" + file;

  const div = document.createElement("div");
  div.className = "file-box";

  let content = "";

  if (file.match(/\.(jpg|png|jpeg|gif)$/)) {
    content += <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;img src="${fileUrl}"&gt;</code>;
  } 
  else if (file.endsWith(".pdf")) {
    content += <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;iframe src="${fileUrl}"&gt;&lt;/iframe&gt;</code>;
  } 
  else {
    content += <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;a href="${fileUrl}" target="_blank"&gt;${file}&lt;/a&gt;</code>;
  }

  div.innerHTML = <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">
</code>    &lt;div&gt;&lt;b&gt;User&lt;/b&gt;&lt;/div&gt;
    ${content}
    &lt;div class="actions"&gt;
      &lt;span&gt;❤️ Like&lt;/span&gt;
      &lt;span&gt;💬 Comment&lt;/span&gt;
      &lt;span&gt;🔗 Share&lt;/span&gt;
    &lt;/div&gt;
  <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">;
</code>
  filesDiv.appendChild(div);
}

// ✅ DELETE
function deleteFile(file) {
  currentFiles = currentFiles.filter(f =&gt; f !== file);
  filesDiv.innerHTML = "";
  currentFiles.forEach(showFile);
}

// ✅ UPLOAD
async function uploadFile() {
  const fileInput = document.getElementById("fileInput");
  const file = fileInput.files[0];

  if (!file) return alert("Select file");

  const formData = new FormData();
  formData.append("file", file);

  const res = await fetch("/upload", {
    method: "POST",
    body: formData
  });

  const data = await res.json();

  // 🔥 FIX: push filename only
  currentFiles.push(data.file);

  showFile(data.file);

  fileInput.value = "";
}

load();
&lt;/script&gt;

&lt;/body&gt;
