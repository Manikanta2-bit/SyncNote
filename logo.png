tive z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">const</span><span> </span><span class="ͼt">socket</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">io</span><span>(</span><span class="ͼr">"http://localhost:3000"</span><span>);</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">editor</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"editor"</span><span>);</span><br><br><span class="ͼl">// Get doc ID from URL</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">docId</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">window</span><span class="ͼn">.</span><span>location</span><span class="ͼn">.</span><span>pathname</span><span class="ͼn">.</span><span>substring(</span><span class="ͼq">1</span><span>) </span><span class="ͼn">||</span><span> </span><span class="ͼr">"default"</span><span>;</span><br><br><span class="ͼl">// Load document</span><br><span class="ͼt">socket</span><span class="ͼn">.</span><span>emit(</span><span class="ͼr">"get-document"</span><span>, </span><span class="ͼt">docId</span><span>);</span><br><br><span class="ͼt">socket</span><span class="ͼn">.</span><span>on(</span><span class="ͼr">"load-document"</span><span>, (</span><span class="ͼt">data</span><span>) =&gt; {</span><br><span>    </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value </span><span class="ͼn">=</span><span> </span><span class="ͼt">data</span><span>;</span><br><span>});</span><br><br><span class="ͼl">// Send changes</span><br><span class="ͼt">editor</span><span class="ͼn">.</span><span>addEventListener(</span><span class="ͼr">"input"</span><span>, () =&gt; {</span><br><span>    </span><span class="ͼt">socket</span><span class="ͼn">.</span><span>emit(</span><span class="ͼr">"send-changes"</span><span>, </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value);</span><br><span>});</span><br><br><span class="ͼl">// Receive changes</span><br><span class="ͼt">socket</span><span class="ͼn">.</span><span>on(</span><span class="ͼr">"receive-changes"</span><span>, (</span><span class="ͼt">data</span><span>) =&gt; {</span><br><span>    </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value </span><span class="ͼn">=</span><span> </span><span class="ͼt">data</span><span>;</span><br><span>});</span><br><br><span class="ͼl">// Auto-save every 2 seconds</span><br><span class="ͼt">setInterval</span><span>(() =&gt; {</span><br><span>    </span><span class="ͼt">socket</span><span class="ͼn">.</span><span>emit(</span><span class="ͼr">"save-document"</span><span>, </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value);</span><br><span>}, </span><span class="ͼq">2000</span><span>);</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
