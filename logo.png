<hr data-start="3308" data-end="3311">
<h1 data-section-id="29v90" data-start="3313" data-end="3339">⚠️ Important limitations</h1>
<ul data-start="3340" data-end="3446">
<li data-section-id="16exb86" data-start="3340" data-end="3382">
<p data-start="3342" data-end="3382">This version uses <strong data-start="3360" data-end="3382">local file storage</strong></p>
</li>
<li data-section-id="1gom9o2" data-start="3383" data-end="3412">
<p data-start="3385" data-end="3412">Not scalable for production</p>
</li>
<li data-section-id="19nyxe1" data-start="3413" data-end="3432">
<p data-start="3415" data-end="3432">No authentication</p>
</li>
<li data-section-id="1901p3z" data-start="3433" data-end="3446">
<p data-start="3435" data-end="3446">No security</p>
</li>
</ul>
