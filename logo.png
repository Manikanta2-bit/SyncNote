<p data-start="907" data-end="939">Open <code data-start="912" data-end="923">server.js</code> and paste this:</p>
<pre class="overflow-visible! px-0!" data-start="941" data-end="1552"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-df3050c8.svg#e45ab3" fill="currentColor"></use></svg>JavaScript</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-df3050c8.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">const</span><span> </span><span class="ͼt">express</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">require</span><span>(</span><span class="ͼr">"express"</span><span>);</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">fs</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">require</span><span>(</span><span class="ͼr">"fs"</span><span>);</span><br><br><span class="ͼn">const</span><span> </span><span class="ͼt">app</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">express</span><span>();</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>use(</span><span class="ͼt">express</span><span class="ͼn">.</span><span>json());</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>use(</span><span class="ͼt">express</span><span class="ͼn">.</span><span>static(</span><span class="ͼt">__dirname</span><span>));</span><br><br><span class="ͼt">app</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"/doc/:id"</span><span>, (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">`data_</span><span>${</span><span class="ͼt">req</span><span class="ͼn">.</span><span>params</span><span class="ͼn">.</span><span>id}</span><span class="ͼr">.txt`</span><span>;</span><br><span>    </span><span class="ͼn">if</span><span> (</span><span class="ͼt">fs</span><span class="ͼn">.</span><span>existsSync(</span><span class="ͼt">file</span><span>)) {</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼt">fs</span><span class="ͼn">.</span><span>readFileSync(</span><span class="ͼt">file</span><span>, </span><span class="ͼr">"utf-8"</span><span>));</span><br><span>    } </span><span class="ͼn">else</span><span> {</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼr">""</span><span>);</span><br><span>    }</span><br><span>});</span><br><br><span class="ͼt">app</span><span class="ͼn">.</span><span>post(</span><span class="ͼr">"/doc/:id"</span><span>, (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">`data_</span><span>${</span><span class="ͼt">req</span><span class="ͼn">.</span><span>params</span><span class="ͼn">.</span><span>id}</span><span class="ͼr">.txt`</span><span>;</span><br><span>    </span><span class="ͼt">fs</span><span class="ͼn">.</span><span>writeFileSync(</span><span class="ͼt">file</span><span>, </span><span class="ͼt">req</span><span class="ͼn">.</span><span>body</span><span class="ͼn">.</span><span>content </span><span class="ͼn">||</span><span> </span><span class="ͼr">""</span><span>);</span><br><span>    </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼr">"saved"</span><span>);</span><br><span>});</span><br><br><span class="ͼt">app</span><span class="ͼn">.</span><span>listen(</span><span class="ͼq">3000</span><span>, () =&gt; {</span><br><span>    </span><span class="ͼt">console</span><span class="ͼn">.</span><span>log(</span><span class="ͼr">"Running on http://localhost:3000"</span><span>);</span><br><span>});</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
