    }
/* Navbar icons */
.navbar span {
  margin-left: 15px;
  cursor: pointer;
}

/* Post style */
.file-box {
  background: white;
  border: 1px solid #ddd;
  padding: 10px;
  border-radius: 8px;
  margin-top: 15px;
}

/* Post actions */
.actions {
  display: flex;
  justify-content: space-around;
  margin-top: 10px;
  color: gray;
  cursor: pointer;
}
textarea {
  width: 100%;
  height: 200px;
  border: none;
  outline: none;
  font-size: 16px;
}

button {
  background: #0A66C2;
  color: white;
  padding: 8px 12px;
  font-size: 14px;
  border: none;
  margin-top: 10px;
  cursor: pointer;
  border-radius: 4px;
}

.file-box {
  margin-top: 10px;
}

    img {
