      color: #0A66C2;
      font-size: 22px;
      font-weight: bold;
    }

    .main {
      display: flex;
      justify-content: center;
      margin-top: 30px;
    }

    .card {
      width: 600px;
      background: #ffffff;
      border-radius: 8px;
      border: 1px solid #e0e0e0;
      padding: 15px;
    }

    .doc-name {
      font-size: 14px;
      color: #666;
      margin-bottom: 10px;
    }

    textarea {
      width: 100%;
      height: 250px;
      border: none;
      outline: none;
      resize: none;
      font-size: 16px;
      line-height: 1.6;
      font-family: inherit;
    }

    .card:hover {
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    /* Upload section */
    .upload-box {
      margin-top: 10px;
    }

    input[type="file"] {
      margin-top: 10px;
    }

    button {
      background: #0A66C2;
      color: white;
      border: none;
      padding: 8px 14px;
      border-radius: 5px;
      cursor: pointer;
      margin-top: 10px;
    }

    button:hover {
      background: #004182;
    }

    /* File preview */
    #files {
      margin-top: 15px;
    }

    img {
      max-width: 100%;
      margin-top: 10px;
      border-radius: 6px;
    }

    a {
      display: block;
      margin-top: 8px;
      color: #0A66C2;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

  &lt;/style&gt;
&lt;/head&gt;

&lt;body&gt;

  &lt;div class="navbar"&gt;
    &lt;div class="logo"&gt;YeahPad&lt;/div&gt;
  &lt;/div&gt;

  &lt;div class="main"&gt;
    &lt;div class="card"&gt;

      &lt;div class="doc-name" id="docName"&gt;&lt;/div&gt;

      &lt;!-- TEXT EDITOR --&gt;
      &lt;textarea id="editor" placeholder="Start writing your thoughts..."&gt;&lt;/textarea&gt;

      &lt;!-- FILE UPLOAD --&gt;
      &lt;div class="upload-box"&gt;
        &lt;input type="file" id="fileInput"&gt;
        &lt;br&gt;
        &lt;button onclick="uploadFile()"&gt;Upload File&lt;/button&gt;
      &lt;/div&gt;

      &lt;!-- FILE DISPLAY --&gt;
      &lt;div id="files"&gt;&lt;/div&gt;

    &lt;/div&gt;
  &lt;/div&gt;

  &lt;script&gt;
    const editor = document.getElementById("editor");
    const docName = document.getElementById("docName");

    const docId = window.location.pathname.substring(1) || "default";
    docName.innerText = "Document: " + docId;

    // LOAD TEXT
    async function load() {
      const res = await fetch("/doc/" + docId);
      editor.value = await res.text();
    }

    // SAVE TEXT
    async function save() {
      await fetch("/doc/" + docId, {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({ content: editor.value })
      });
    }

    setInterval(save, 2000);
    load();

    // 🔥 FILE UPLOAD FUNCTION
    async function uploadFile() {
      const fileInput = document.getElementById("fileInput");
      const file = fileInput.files[0];

      if (!file) {
        alert("Please select a file");
        return;
      }

      const formData = new FormData();
      formData.append("file", file);

      const res = await fetch("/upload", {
        method: "POST",
        body: formData
      });

      const data = await res.json();

      const fileUrl = "/uploads/" + data.file;

      const div = document.getElementById("files");

      // Show image preview
      if (file.type.startsWith("image")) {
        div.innerHTML += <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;img src="${fileUrl}"&gt;</code>;
      } else {
        div.innerHTML += <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">&lt;a href="${fileUrl}" target="_blank"&gt;📄 ${data.file}&lt;/a&gt;</code>;
      }
    }
  &lt;/script&gt;

&lt;/body&gt;
&lt;/html&gt; this is my html part edit the required and give me</div></div></div></div></div><div class="z-0 flex justify-end"><div aria-label="Your message actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none focus-within:transition-none hover:transition-none touch:pointer-events-auto touch:opacity-100 duration-300 group-hover/turn-messages:delay-300 pointer-events-none opacity-0 motion-safe:transition-opacity group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:opacity-100 group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:opacity-100 has-data-[state=open]:pointer-events-auto has-data-[state=open]:opacity-100" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy message" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-df3050c8.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Edit message" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-df3050c8.svg#6d87e1" fill="currentColor"></use></svg></span></button></div></div></div></div><span class="sr-only"><br></span></section><section class="text-token-text-primary w-full focus:outline-none [--shadow-height:45px] has-data-writing-block:pointer-events-none has-data-writing-block:-mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto scroll-mt-[calc(var(--header-height)+min(2