&lt;html&gt;
&lt;head&gt;
  &lt;title&gt;YeahPad&lt;/title&gt;
  &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;

  &lt;style&gt;
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto;
      background-color: #F3F2EF;
    }

    /* Navbar */
    .navbar {
      background: #ffffff;
      display: flex;
      align-items: center;
      padding: 10px 20px;
      border-bottom: 1px solid #e0e0e0;
    }

    .logo {
      color: #0A66C2;
      font-size: 22px;
      font-weight: bold;
    }

    /* Main layout */
    .main {
      display: flex;
      justify-content: center;
      margin-top: 30px;
    }

    .card {
      width: 600px;
      background: #ffffff;
      border-radius: 8px;
      border: 1px solid #e0e0e0;
      padding: 15px;
    }

    .doc-name {
      font-size: 14px;
      color: #666;
      margin-bottom: 10px;
    }

    textarea {
      width: 100%;
      height: 400px;
      border: none;
      outline: none;
      resize: none;
      font-size: 16px;
      line-height: 1.6;
      font-family: inherit;
    }

    /* Subtle hover like LinkedIn */
    .card:hover {
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

  &lt;/style&gt;
&lt;/head&gt;

&lt;body&gt;

  &lt;!-- Navbar --&gt;
  &lt;div class="navbar"&gt;
    &lt;div class="logo"&gt;YeahPad&lt;/div&gt;
  &lt;/div&gt;

  &lt;!-- Main --&gt;
  &lt;div class="main"&gt;
    &lt;div class="card"&gt;
      &lt;div class="doc-name" id="docName"&gt;&lt;/div&gt;
      &lt;textarea id="editor" placeholder="Start writing your thoughts..."&gt;&lt;/textarea&gt;
    &lt;/div&gt;
  &lt;/div&gt;

  &lt;script&gt;
    const editor = document.getElementById("editor");
    const docName = document.getElementById("docName");

    const docId = window.location.pathname.substring(1) || "default";
    docName.innerText = "Document: " + docId;

    async function load() {
      const res = await fetch("/doc/" + docId);
      editor.value = await res.text();
    }

    async function save() {
      await fetch("/doc/" + docId, {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({ content: editor.value })
      });
    }

    setInterval(save, 2000);
    load();
  &lt;/script&gt;

&lt;/body&gt;
