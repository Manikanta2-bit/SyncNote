    body {const express = require("express");
const fs = require("fs");
const path = require("path");
const multer = require("multer");
const { CloudinaryStorage } = require("multer-storage-cloudinary");
const cloudinary = require("cloudinary").v2;

cloudinary.config({
    cloud_name: "dyfmgwwjn",
    api_key: "241586278216817",
    api_secret: "ipjzbMhO7TxY6oGVtggQP5gRako"
});
const app = express();

app.use(express.json());
app.use(express.static(__dirname));

// Upload folder
const uploadDir = path.join(__dirname, "uploads");
if (!fs.existsSync(uploadDir)) {
    fs.mkdirSync(uploadDir);
}

// Multer setup
const storage = new CloudinaryStorage({
    cloudinary: cloudinary,
    params: {
        folder: "yeahpad",
        resource_type: "auto"
    }
});

const upload = multer({ storage });

// Upload API
app.post("/upload", upload.single("file"), (req, res) =&gt; {
    res.json({ url: req.file.path });
});

// Serve files
app.use("/uploads", express.static(uploadDir));

// Get doc
app.get("/doc/:id", (req, res) =&gt; {
    const file = path.join(__dirname, <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">data_${req.params.id}.json</code>);

    if (fs.existsSync(file)) {
        res.json(JSON.parse(fs.readFileSync(file)));
    } else {
        res.json({ content: "", files: [] });
    }
});

// Save doc
app.post("/doc/:id", (req, res) =&gt; {
    const file = path.join(__dirname, <code class="rounded-sm bg-(--theme-user-msg-text)/10 dark:bg-(--theme-user-msg-text)/15 px-1 py-0.5 text-(--theme-user-msg-text) text-sm">data_${req.params.id}.json</code>);
    fs.writeFileSync(file, JSON.stringify(req.body));
    res.send("saved");
});

// Catch all
app.use((req, res) =&gt; {
    res.sendFile(path.join(__dirname, "index.html"));
});

const PORT = process.env.PORT || 3000;

app.listen(PORT, () =&gt; {
    console.log("Server running on port " + PORT);
});this are my html and server.js files now add 
      margin: 0;   
      font-family: "Segoe UI", Roboto;
      background-color: #F3F2EF;
    }

    .navbar {
      background: #fff;
      padding: 10px 20px;
      border-bottom: 1px solid #ddd;
    }

    .logo {
      color: #0A66C2;
