<pre class="overflow-visible! px-0!" data-start="1668" data-end="2340"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-df3050c8.svg#e45ab3" fill="currentColor"></use></svg>JavaScript</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-df3050c8.svg#ce3544" fill="currentColor"></use></svg></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">function</span><span> </span><span class="ͼt">showFile</span><span>(</span><span class="ͼt">file</span><span>) {</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">fileUrl</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">"/uploads/"</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">file</span><span>;</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">div</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>createElement(</span><span class="ͼr">"div"</span><span>);</span><br><span>  </span><span class="ͼt">div</span><span class="ͼn">.</span><span>className </span><span class="ͼn">=</span><span> </span><span class="ͼr">"file-box"</span><span>;</span><br><br><span>  </span><span class="ͼn">let</span><span> </span><span class="ͼt">content</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">""</span><span>;</span><br><br><span>  </span><span class="ͼn">if</span><span> (</span><span class="ͼt">file</span><span class="ͼn">.</span><span>match(</span><span class="ͼr">/\.(jpg|png|jpeg|gif)$/</span><span>)) {</span><br><span>    </span><span class="ͼt">content</span><span> </span><span class="ͼn">+=</span><span> </span><span class="ͼr">`&lt;img src="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">"&gt;`</span><span>;</span><br><span>  } </span><br><span>  </span><span class="ͼn">else</span><span> </span><span class="ͼn">if</span><span> (</span><span class="ͼt">file</span><span class="ͼn">.</span><span>endsWith(</span><span class="ͼr">".pdf"</span><span>)) {</span><br><span>    </span><span class="ͼt">content</span><span> </span><span class="ͼn">+=</span><span> </span><span class="ͼr">`&lt;iframe src="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">"&gt;&lt;/iframe&gt;`</span><span>;</span><br><span>  } </span><br><span>  </span><span class="ͼn">else</span><span> {</span><br><span>    </span><span class="ͼt">content</span><span> </span><span class="ͼn">+=</span><span> </span><span class="ͼr">`&lt;a href="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">" target="_blank"&gt;</span><span>${</span><span class="ͼt">file</span><span>}</span><span class="ͼr">&lt;/a&gt;`</span><span>;</span><br><span>  }</span><br><br><span>  </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼr">`</span><br><span class="ͼr">    &lt;div&gt;&lt;b&gt;User&lt;/b&gt;&lt;/div&gt;</span><br><span class="ͼr">    </span><span>${</span><span class="ͼt">content</span><span>}</span><br><span class="ͼr">    &lt;div class="actions"&gt;</span><br><span class="ͼr">      &lt;span&gt;❤️ Like&lt;/span&gt;</span><br><span class="ͼr">      &lt;span&gt;💬 Comment&lt;/span&gt;</span><br><span class="ͼr">      &lt;span&gt;🔗 Share&lt;/span&gt;</span><br><span class="ͼr">    &lt;/div&gt;</span><br><span class="ͼr">  `</span><span>;</span><br><br><span>  </span><span class="ͼt">filesDiv</span><span class="ͼn">.</span><span>appendChild(</span><span class="ͼt">div</span><span>);</span><br><span>}</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
