><span>: </span><span class="ͼr">"application/json"</span><span>},</span><br><span>        body: </span><span class="ͼt">JSON</span><span class="ͼn">.</span><span>stringify({ content: </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value })</span><br><span>      });</span><br><span>    }</span><br><br><span>    </span><span class="ͼt">setInterval</span><span>(</span><span class="ͼt">save</span><span>, </span><span class="ͼq">2000</span><span>);</span><br><span>    </span><span class="ͼt">load</span><span>();</span><br><span>  </span><span class="ͼv">&lt;/script&gt;</span><br><br><span class="ͼv">&lt;/body&gt;</span><br><span class="ͼv">&lt;/html&gt;</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
