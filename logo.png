an class="ͼn">.</span><span>env</span><span class="ͼn">.</span><span>CLOUD_NAME,</span><br><span>    api_key: </span><span class="ͼt">process</span><span class="ͼn">.</span><span>env</span><span class="ͼn">.</span><span>API_KEY,</span><br><span>    api_secret: </span><span class="ͼt">process</span><span class="ͼn">.</span><span>env</span><span class="ͼn">.</span><span>API_SECRET</span><br><span>});</span><br><br><span class="ͼl">// Middleware</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>use(</span><span class="ͼt">express</span><span class="ͼn">.</span><span>json());</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>use(</span><span class="ͼt">express</span><span class="ͼn">.</span><span>static(</span><span class="ͼt">__dirname</span><span>));</span><br><br><span class="ͼl">// 📦 Cloudinary Storage</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">storage</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">new</span><span> </span><span class="ͼt">CloudinaryStorage</span><span>({</span><br><span>    cloudinary: </span><span class="ͼt">cloudinary</span><span>,</span><br><span>    params: {</span><br><span>        folder: </span><span class="ͼr">"yeahpad"</span><span>,</span><br><span>        resource_type: </span><span class="ͼr">"auto"</span><br><span>    }</span><br><span>});</span><br><br><span class="ͼl">// 📤 Upload setup (with limit)</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">upload</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">multer</span><span>({</span><br><span>    storage,</span><br><span>    limits: { fileSize: </span><span class="ͼq">10</span><span> </span><span class="ͼn">*</span><span> </span><span class="ͼq">1024</span><span> </span><span class="ͼn">*</span><span> </span><span class="ͼq">1024</span><span> } </span><span class="ͼl">// 10MB</span><br><span>});</span><br><br><span class="ͼl">// 📤 Upload API</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>post(</span><span class="ͼr">"/upload"</span><span>, </span><span class="ͼt">upload</span><span class="ͼn">.</span><span>single(</span><span class="ͼr">"file"</span><span>), (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">try</span><span> {</span><br><span>        </span><span class="ͼn">if</span><span> (</span><span class="ͼn">!</span><span class="ͼt">req</span><span class="ͼn">.</span><span>file) {</span><br><span>            </span><span class="ͼn">return</span><span> </span><span class="ͼt">res</span><span class="ͼn">.</span><span>status(</span><span class="ͼq">400</span><span>)</span><span class="ͼn">.</span><span>json({ error: </span><span class="ͼr">"No file uploaded"</span><span> });</span><br><span>        }</span><br><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>json({ url: </span><span class="ͼt">req</span><span class="ͼn">.</span><span>file</span><span class="ͼn">.</span><span>path });</span><br><br><span>    } </span><span class="ͼn">catch</span><span> (</span><span class="ͼt">err</span><span>) {</span><br><span>        </span><span class="ͼt">console</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">"Upload error:"</span><span>, </span><span class="ͼt">err</span><span>);</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>status(</span><span class="ͼq">500</span><span>)</span><span class="ͼn">.</span><span>json({ error: </span><span class="ͼr">"Upload failed"</span><span> });</span><br><span>    }</span><br><span>});</span><br><br><span class="ͼl">// 📄 Get document</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"/doc/:id"</span><span>, (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">try</span><span> {</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">path</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">__dirname</span><span>, </span><span class="ͼr">`data_</span><span>${</span><span class="ͼt">req</span><span class="ͼn">.</span><span>params</span><span class="ͼn">.</span><span>id}</span><span class="ͼr">.json`</span><span>);</span><br><br><span>        </span><span class="ͼn">if</span><span> (</span><span class="ͼt">fs</span><span class="ͼn">.</span><span>existsSync(</span><span class="ͼt">file</span><span>)) {</span><br><span>            </span><span class="ͼt">res</span><span class="ͼn">.</span><span>json(</span><span class="ͼt">JSON</span><span class="ͼn">.</span><span>parse(</span><span class="ͼt">fs</span><span class="ͼn">.</span><span>readFileSync(</span><span class="ͼt">file</span><span>)));</span><br><span>        } </span><span class="ͼn">else</span><span> {</span><br><span>            </span><span class="ͼt">res</span><span class="ͼn">.</span><span>json({ content: </span><span class="ͼr">""</span><span>, files: [] });</span><br><span>        }</span><br><br><span>    } </span><span class="ͼn">catch</span><span> (</span><span class="ͼt">err</span><span>) {</span><br><span>        </span><span class="ͼt">console</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">"Read error:"</span><span>, </span><span class="ͼt">err</span><span>);</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>status(</span><span class="ͼq">500</span><span>)</span><span class="ͼn">.</span><span>json({ error: </span><span class="ͼr">"Read failed"</span><span> });</span><br><span>    }</span><br><span>});</span><br><br><span class="ͼl">// 💾 Save document</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>post(</span><span class="ͼr">"/doc/:id"</span><span>, (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">try</span><span> {</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">path</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">__dirname</span><span>, </span><span class="ͼr">`data_</span><span>${</span><span class="ͼt">req</span><span class="ͼn">.</span><span>params</span><span class="ͼn">.</span><span>id}</span><span class="ͼr">.json`</span><span>);</span><br><span>        </span><span class="ͼt">fs</span><span class="ͼn">.</span><span>writeFileSync(</span><span class="ͼt">file</span><span>, </span><span class="ͼt">JSON</span><span class="ͼn">.</span><span>stringify(</span><span class="ͼt">req</span><span class="ͼn">.</span><span>body));</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼr">"saved"</span><span>);</span><br><br><span>    } </span><span class="ͼn">catch</span><span> (</span><span class="ͼt">err</span><span>) {</span><br><span>        </span><span class="ͼt">console</span><span class="ͼn">.</span><span>error(</span><span class="ͼr">"Save error:"</span><span>, </span><span class="ͼt">err</span><span>);</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>status(</span><span class="ͼq">500</span><span>)</span><span class="ͼn">.</span><span>json({ error: </span><span class="ͼr">"Save failed"</span><span> });</span><br><span>    }</span><br><span>});</span><br><br><span class="ͼl">// 🌐 Catch-all route</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>use((</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼt">res</span><span class="ͼn">.</span><span>sendFile(</span><span class="ͼt">path</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">__dirname</span><span>, </span><span class="ͼr">"index.html"</span><span>));</span><br><span>});</span><br><br><span class="ͼl">// 🚀 Start server</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">PORT</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">process</span><span class="ͼn">.</span><span>env</span><span class="ͼn">.</span><span>PORT </span><span class="ͼn">||</span><span> </span><span class="ͼq">3000</span><span>;</span><br><br><span class="ͼt">app</span><span class="ͼn">.</span><span>listen(</span><span class="ͼt">PORT</span><span>, () =&gt; {</span><br><span>    </span><span class="ͼt">console</span><span class="ͼn">.</span><span>log(</span><span class="ͼr">"Server running on port "</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">PORT</span><span>);</span><br><span>});</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
