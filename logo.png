pan><span class="ͼr">"uploads"</span><span>);</span><br><span class="ͼn">if</span><span> (</span><span class="ͼn">!</span><span class="ͼt">fs</span><span class="ͼn">.</span><span>existsSync(</span><span class="ͼt">uploadDir</span><span>)) {</span><br><span>    </span><span class="ͼt">fs</span><span class="ͼn">.</span><span>mkdirSync(</span><span class="ͼt">uploadDir</span><span>);</span><br><span>}</span><br><br><span class="ͼl">// ⚙️ Multer setup</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">storage</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">multer</span><span class="ͼn">.</span><span>diskStorage({</span><br><span>    destination: (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">file</span><span>, </span><span class="ͼt">cb</span><span>) =&gt; {</span><br><span>        </span><span class="ͼt">cb</span><span>(</span><span class="ͼq">null</span><span>, </span><span class="ͼt">uploadDir</span><span>);</span><br><span>    },</span><br><span>    filename: (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">file</span><span>, </span><span class="ͼt">cb</span><span>) =&gt; {</span><br><span>        </span><span class="ͼn">const</span><span> </span><span class="ͼt">uniqueName</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Date</span><span class="ͼn">.</span><span>now() </span><span class="ͼn">+</span><span> </span><span class="ͼr">"-"</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">file</span><span class="ͼn">.</span><span>originalname;</span><br><span>        </span><span class="ͼt">cb</span><span>(</span><span class="ͼq">null</span><span>, </span><span class="ͼt">uniqueName</span><span>);</span><br><span>    }</span><br><span>});</span><br><br><span class="ͼn">const</span><span> </span><span class="ͼt">upload</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">multer</span><span>({</span><br><span>    storage,</span><br><span>    limits: { fileSize: </span><span class="ͼq">10</span><span> </span><span class="ͼn">*</span><span> </span><span class="ͼq">1024</span><span> </span><span class="ͼn">*</span><span> </span><span class="ͼq">1024</span><span> } </span><span class="ͼl">// 10MB limit</span><br><span>});</span><br><br><span class="ͼl">// 📤 Upload route</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>post(</span><span class="ͼr">"/upload"</span><span>, </span><span class="ͼt">upload</span><span class="ͼn">.</span><span>single(</span><span class="ͼr">"file"</span><span>), (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">if</span><span> (</span><span class="ͼn">!</span><span class="ͼt">req</span><span class="ͼn">.</span><span>file) {</span><br><span>        </span><span class="ͼn">return</span><span> </span><span class="ͼt">res</span><span class="ͼn">.</span><span>status(</span><span class="ͼq">400</span><span>)</span><span class="ͼn">.</span><span>json({ error: </span><span class="ͼr">"No file uploaded"</span><span> });</span><br><span>    }</span><br><br><span>    </span><span class="ͼt">console</span><span class="ͼn">.</span><span>log(</span><span class="ͼr">"Uploaded:"</span><span>, </span><span class="ͼt">req</span><span class="ͼn">.</span><span>file</span><span class="ͼn">.</span><span>filename); </span><span class="ͼl">// debug log</span><br><br><span>    </span><span class="ͼt">res</span><span class="ͼn">.</span><span>json({ file: </span><span class="ͼt">req</span><span class="ͼn">.</span><span>file</span><span class="ͼn">.</span><span>filename });</span><br><span>});</span><br><br><span class="ͼl">// ✅ IMPORTANT: Serve uploads correctly</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>use(</span><span class="ͼr">"/uploads"</span><span>, </span><span class="ͼt">express</span><span class="ͼn">.</span><span>static(</span><span class="ͼt">uploadDir</span><span>));</span><br><br><span class="ͼl">// 📄 Get document</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"/doc/:id"</span><span>, (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">filePath</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">path</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">__dirname</span><span>, </span><span class="ͼr">`data_</span><span>${</span><span class="ͼt">req</span><span class="ͼn">.</span><span>params</span><span class="ͼn">.</span><span>id}</span><span class="ͼr">.txt`</span><span>);</span><br><br><span>    </span><span class="ͼn">if</span><span> (</span><span class="ͼt">fs</span><span class="ͼn">.</span><span>existsSync(</span><span class="ͼt">filePath</span><span>)) {</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼt">fs</span><span class="ͼn">.</span><span>readFileSync(</span><span class="ͼt">filePath</span><span>, </span><span class="ͼr">"utf-8"</span><span>));</span><br><span>    } </span><span class="ͼn">else</span><span> {</span><br><span>        </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼr">""</span><span>);</span><br><span>    }</span><br><span>});</span><br><br><span class="ͼl">// 💾 Save document</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>post(</span><span class="ͼr">"/doc/:id"</span><span>, (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼn">const</span><span> </span><span class="ͼt">filePath</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">path</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">__dirname</span><span>, </span><span class="ͼr">`data_</span><span>${</span><span class="ͼt">req</span><span class="ͼn">.</span><span>params</span><span class="ͼn">.</span><span>id}</span><span class="ͼr">.txt`</span><span>);</span><br><span>    </span><span class="ͼt">fs</span><span class="ͼn">.</span><span>writeFileSync(</span><span class="ͼt">filePath</span><span>, </span><span class="ͼt">req</span><span class="ͼn">.</span><span>body</span><span class="ͼn">.</span><span>content </span><span class="ͼn">||</span><span> </span><span class="ͼr">""</span><span>);</span><br><span>    </span><span class="ͼt">res</span><span class="ͼn">.</span><span>send(</span><span class="ͼr">"saved"</span><span>);</span><br><span>});</span><br><br><span class="ͼl">// 🌐 Catch-all route</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>use((</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼt">res</span><span class="ͼn">.</span><span>sendFile(</span><span class="ͼt">path</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">__dirname</span><span>, </span><span class="ͼr">"index.html"</span><span>));</span><br><span>});</span><br><br><span class="ͼl">// 🚀 Start server</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>listen(</span><span class="ͼq">3000</span><span>, () =&gt; {</span><br><span>    </span><span class="ͼt">console</span><span class="ͼn">.</span><span>log(</span><span class="ͼr">"Server running on http://localhost:3000"</span><span>);</span><br><span>});</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
