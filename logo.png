tive z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">const</span><span> </span><span class="ͼt">firebaseConfig</span><span> </span><span class="ͼn">=</span><span> {</span><br><span>  apiKey: </span><span class="ͼr">"..."</span><span>,</span><br><span>  authDomain: </span><span class="ͼr">"..."</span><span>,</span><br><span>  projectId: </span><span class="ͼr">"..."</span><span>,</span><br><span>};</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
