ve z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">const</span><span> </span><span class="ͼt">path</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">require</span><span>(</span><span class="ͼr">"path"</span><span>);</span><br><br><span class="ͼl">// Serve index.html for all routes</span><br><span class="ͼt">app</span><span class="ͼn">.</span><span>get(</span><span class="ͼr">"*"</span><span>, (</span><span class="ͼt">req</span><span>, </span><span class="ͼt">res</span><span>) =&gt; {</span><br><span>    </span><span class="ͼt">res</span><span class="ͼn">.</span><span>sendFile(</span><span class="ͼt">path</span><span class="ͼn">.</span><span>join(</span><span class="ͼt">__dirname</span><span>, </span><span class="ͼr">"index.html"</span><span>));</span><br><span>});</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
