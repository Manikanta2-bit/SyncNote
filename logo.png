<hr data-start="920" data-end="923">
<h1 data-section-id="1h07tsx" data-start="925" data-end="954">🚀 STEP 2: Deploy on Render</h1>
<ol data-start="956" data-end="1075">
<li data-section-id="ogx9ml" data-start="956" data-end="985">
<p data-start="959" data-end="985">Go to <a data-start="965" data-end="983" rel="noopener" target="_new" class="decorated-link" href="https://render.com/">https://render.com<span aria-hidden="true" class="ms-0.5 inline-block align-middle leading-none"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" data-rtl-flip="" class="block h-[0.75em] w-[0.75em] stroke-current stroke-[0.75]"><use href="/cdn/assets/sprites-core-df3050c8.svg#304883" fill="currentColor"></use></svg></span></a></p>
</li>
<li data-section-id="1mh5tjc" data-start="986" data-end="1010">
<p data-start="989" data-end="1010">Sign up with GitHub</p>
</li>
<li data-section-id="10tynud" data-start="1011" data-end="1043">
