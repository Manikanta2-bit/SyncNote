;</span><br><br><span>    </span><span class="ͼv">&lt;input</span><span> </span><span class="ͼu">type</span><span class="ͼn">=</span><span class="ͼr">"file"</span><span> </span><span class="ͼu">id</span><span class="ͼn">=</span><span class="ͼr">"fileInput"</span><span class="ͼv">&gt;</span><br><span>    </span><span class="ͼv">&lt;button</span><span> </span><span class="ͼu">onclick</span><span class="ͼn">=</span><span class="ͼr">"</span><span class="ͼt">uploadFile</span><span>()</span><span class="ͼr">"</span><span class="ͼv">&gt;</span><span>Upload</span><span class="ͼv">&lt;/button&gt;</span><br><br><span>    </span><span class="ͼv">&lt;div</span><span> </span><span class="ͼu">id</span><span class="ͼn">=</span><span class="ͼr">"files"</span><span class="ͼv">&gt;&lt;/div&gt;</span><br><br><span>  </span><span class="ͼv">&lt;/div&gt;</span><br><span class="ͼv">&lt;/div&gt;</span><br><br><span class="ͼv">&lt;script&gt;</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">editor</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"editor"</span><span>);</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">filesDiv</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"files"</span><span>);</span><br><span class="ͼn">const</span><span> </span><span class="ͼt">docName</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"docName"</span><span>);</span><br><br><span class="ͼn">const</span><span> </span><span class="ͼt">docId</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">window</span><span class="ͼn">.</span><span>location</span><span class="ͼn">.</span><span>pathname</span><span class="ͼn">.</span><span>substring(</span><span class="ͼq">1</span><span>) </span><span class="ͼn">||</span><span> </span><span class="ͼr">"default"</span><span>;</span><br><span class="ͼt">docName</span><span class="ͼn">.</span><span>innerText </span><span class="ͼn">=</span><span> </span><span class="ͼr">"Document: "</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">docId</span><span>;</span><br><br><span class="ͼn">let</span><span> </span><span class="ͼt">currentFiles</span><span> </span><span class="ͼn">=</span><span> [];</span><br><br><span class="ͼl">// ✅ LOAD</span><br><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">load</span><span>() {</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">res</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">"/doc/"</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">docId</span><span>);</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">data</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">res</span><span class="ͼn">.</span><span>json();</span><br><br><span>  </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value </span><span class="ͼn">=</span><span> </span><span class="ͼt">data</span><span class="ͼn">.</span><span>content </span><span class="ͼn">||</span><span> </span><span class="ͼr">""</span><span>;</span><br><span>  </span><span class="ͼt">currentFiles</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">data</span><span class="ͼn">.</span><span>files </span><span class="ͼn">||</span><span> [];</span><br><br><span>  </span><span class="ͼt">filesDiv</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼr">""</span><span>;</span><br><br><span>  </span><span class="ͼl">// 🔥 IMPORTANT: render files</span><br><span>  </span><span class="ͼt">currentFiles</span><span class="ͼn">.</span><span>forEach(</span><span class="ͼt">showFile</span><span>);</span><br><span>}</span><br><br><span class="ͼl">// ✅ SAVE</span><br><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">save</span><span>() {</span><br><span>  </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">"/doc/"</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">docId</span><span>, {</span><br><span>    method: </span><span class="ͼr">"POST"</span><span>,</span><br><span>    headers: {</span><span class="ͼr">"Content-Type"</span><span>: </span><span class="ͼr">"application/json"</span><span>},</span><br><span>    body: </span><span class="ͼt">JSON</span><span class="ͼn">.</span><span>stringify({</span><br><span>      content: </span><span class="ͼt">editor</span><span class="ͼn">.</span><span>value,</span><br><span>      files: </span><span class="ͼt">currentFiles</span><br><span>    })</span><br><span>  });</span><br><span>}</span><br><br><span class="ͼt">setInterval</span><span>(</span><span class="ͼt">save</span><span>, </span><span class="ͼq">2000</span><span>);</span><br><br><span class="ͼl">// ✅ SHOW FILE</span><br><span class="ͼn">function</span><span> </span><span class="ͼt">showFile</span><span>(</span><span class="ͼt">file</span><span>) {</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">fileUrl</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼr">"/uploads/"</span><span> </span><span class="ͼn">+</span><span> </span><span class="ͼt">file</span><span>;</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">div</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>createElement(</span><span class="ͼr">"div"</span><span>);</span><br><span>  </span><span class="ͼt">div</span><span class="ͼn">.</span><span>className </span><span class="ͼn">=</span><span> </span><span class="ͼr">"file-box"</span><span>;</span><br><br><span>  </span><span class="ͼn">if</span><span> (</span><span class="ͼt">file</span><span class="ͼn">.</span><span>match(</span><span class="ͼr">/\.(jpg|png|jpeg|gif)$/</span><span>)) {</span><br><span>    </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼr">`&lt;img src="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">"&gt;`</span><span>;</span><br><span>  } </span><br><span>  </span><span class="ͼn">else</span><span> </span><span class="ͼn">if</span><span> (</span><span class="ͼt">file</span><span class="ͼn">.</span><span>endsWith(</span><span class="ͼr">".pdf"</span><span>)) {</span><br><span>    </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼr">`&lt;iframe src="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">"&gt;&lt;/iframe&gt;`</span><span>;</span><br><span>  } </span><br><span>  </span><span class="ͼn">else</span><span> {</span><br><span>    </span><span class="ͼt">div</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼr">`&lt;a href="</span><span>${</span><span class="ͼt">fileUrl</span><span>}</span><span class="ͼr">" target="_blank"&gt;</span><span>${</span><span class="ͼt">file</span><span>}</span><span class="ͼr">&lt;/a&gt;`</span><span>;</span><br><span>  }</span><br><br><span>  </span><span class="ͼl">// delete button</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">btn</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>createElement(</span><span class="ͼr">"button"</span><span>);</span><br><span>  </span><span class="ͼt">btn</span><span class="ͼn">.</span><span>innerText </span><span class="ͼn">=</span><span> </span><span class="ͼr">"Delete"</span><span>;</span><br><span>  </span><span class="ͼt">btn</span><span class="ͼn">.</span><span>onclick </span><span class="ͼn">=</span><span> () =&gt; </span><span class="ͼt">deleteFile</span><span>(</span><span class="ͼt">file</span><span>);</span><br><br><span>  </span><span class="ͼt">div</span><span class="ͼn">.</span><span>appendChild(</span><span class="ͼt">btn</span><span>);</span><br><span>  </span><span class="ͼt">filesDiv</span><span class="ͼn">.</span><span>appendChild(</span><span class="ͼt">div</span><span>);</span><br><span>}</span><br><br><span class="ͼl">// ✅ DELETE</span><br><span class="ͼn">function</span><span> </span><span class="ͼt">deleteFile</span><span>(</span><span class="ͼt">file</span><span>) {</span><br><span>  </span><span class="ͼt">currentFiles</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">currentFiles</span><span class="ͼn">.</span><span>filter(</span><span class="ͼt">f</span><span> =&gt; </span><span class="ͼt">f</span><span> </span><span class="ͼn">!==</span><span> </span><span class="ͼt">file</span><span>);</span><br><span>  </span><span class="ͼt">filesDiv</span><span class="ͼn">.</span><span>innerHTML </span><span class="ͼn">=</span><span> </span><span class="ͼr">""</span><span>;</span><br><span>  </span><span class="ͼt">currentFiles</span><span class="ͼn">.</span><span>forEach(</span><span class="ͼt">showFile</span><span>);</span><br><span>}</span><br><br><span class="ͼl">// ✅ UPLOAD</span><br><span class="ͼn">async</span><span> </span><span class="ͼn">function</span><span> </span><span class="ͼt">uploadFile</span><span>() {</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">fileInput</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>getElementById(</span><span class="ͼr">"fileInput"</span><span>);</span><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">file</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">fileInput</span><span class="ͼn">.</span><span>files[</span><span class="ͼq">0</span><span>];</span><br><br><span>  </span><span class="ͼn">if</span><span> (</span><span class="ͼn">!</span><span class="ͼt">file</span><span>) </span><span class="ͼn">return</span><span> </span><span class="ͼt">alert</span><span>(</span><span class="ͼr">"Select file"</span><span>);</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">formData</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">new</span><span> </span><span class="ͼt">FormData</span><span>();</span><br><span>  </span><span class="ͼt">formData</span><span class="ͼn">.</span><span>append(</span><span class="ͼr">"file"</span><span>, </span><span class="ͼt">file</span><span>);</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">res</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">fetch</span><span>(</span><span class="ͼr">"/upload"</span><span>, {</span><br><span>    method: </span><span class="ͼr">"POST"</span><span>,</span><br><span>    body: </span><span class="ͼt">formData</span><br><span>  });</span><br><br><span>  </span><span class="ͼn">const</span><span> </span><span class="ͼt">data</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼn">await</span><span> </span><span class="ͼt">res</span><span class="ͼn">.</span><span>json();</span><br><br><span>  </span><span class="ͼl">// 🔥 FIX: push filename only</span><br><span>  </span><span class="ͼt">currentFiles</span><span class="ͼn">.</span><span>push(</span><span class="ͼt">data</span><span class="ͼn">.</span><span>file);</span><br><br><span>  </span><span class="ͼt">showFile</span><span>(</span><span class="ͼt">data</span><span class="ͼn">.</span><span>file);</span><br><br><span>  </span><span class="ͼt">fileInput</span><span class="ͼn">.</span><span>value </span><span class="ͼn">=</span><span> </span><span class="ͼr">""</span><span>;</span><br><span>}</span><br><br><span class="ͼt">load</span><span>();</span><br><span class="ͼv">&lt;/script&gt;</span><br><br><span class="ͼv">&lt;/body&gt;</span><br><span class="ͼv">&lt;/html&gt;</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
